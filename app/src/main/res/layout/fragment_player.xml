<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" />

    <!-- HUD top bar (auto-hide) -->
    <FrameLayout
        android:id="@+id/hud_top"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_top_bar_gradient"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_card_glass_input"
            android:contentDescription="@string/player_back_desc"
            android:padding="8dp"
            android:rotation="90"
            android:src="@drawable/ic_feed_menu_24"
            android:tint="@color/text_primary" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="52dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            tools:text="> video_title.mp4" />
    </FrameLayout>

    <!-- Page indicator dots -->
    <LinearLayout
        android:id="@+id/dot_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Page counter -->
    <TextView
        android:id="@+id/text_page_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="24dp"
        android:fontFamily="monospace"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        tools:text="03/15" />
</FrameLayout>
