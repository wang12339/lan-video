<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxWidth="400dp"
    android:background="@drawable/bg_card_glass"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="28dp"
    android:paddingTop="32dp"
    android:paddingBottom="28dp">

    <!-- Neon icon area -->
    <View
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_avatar_glow" />

    <TextView
        android:id="@+id/login_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:shadowColor="@color/neon_cyan"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10"
        android:text="@string/login_title"
        android:textColor="@color/neon_cyan"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/login_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="@string/login_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Username -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_username_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:hint="@string/login_username_hint"
        app:boxBackgroundColor="#1A152040"
        app:boxCornerRadiusBottomEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusTopStart="10dp"
        app:boxStrokeColor="@color/glass_stroke_cyan"
        app:hintTextColor="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:imeOptions="actionNext"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_password_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/login_password_hint"
        app:boxBackgroundColor="#1A152040"
        app:boxCornerRadiusBottomEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusTopStart="10dp"
        app:boxStrokeColor="@color/glass_stroke_cyan"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/text_muted"
        app:hintTextColor="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:imeOptions="actionDone"
            android:inputType="textPassword"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm password -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_confirm_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/login_confirm_hint"
        android:visibility="gone"
        app:boxBackgroundColor="#1A152040"
        app:boxCornerRadiusBottomEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusTopStart="10dp"
        app:boxStrokeColor="@color/glass_stroke_cyan"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/text_muted"
        app:hintTextColor="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:imeOptions="actionDone"
            android:inputType="textPassword"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Error text -->
    <TextView
        android:id="@+id/text_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textColor="@color/neon_red"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Submit button (neon gradient) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_neon_gradient"
        android:fontFamily="monospace"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:letterSpacing="0.08"
        android:text="@string/login_btn_login"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:cornerRadius="25dp" />

    <!-- Toggle mode -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle_mode"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/login_toggle_register"
        android:textColor="@color/neon_cyan"
        android:textSize="12sp" />

    <!-- Server config -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_server_config"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/access_gate_server_config"
        android:textColor="@color/text_muted"
        android:textSize="12sp" />
</LinearLayout>
