<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_tech">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Connection status bar -->
        <LinearLayout
            android:id="@+id/user_connection_status"
            android:layout_width="match_parent"
            android:layout_height="@dimen/status_bar_height"
            android:background="@drawable/bg_status_bar"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="gone">

            <View
                android:id="@+id/user_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_status_pulse" />

            <TextView
                android:id="@+id/user_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="80dp"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Avatar with neon glow -->
                <TextView
                    android:id="@+id/user_avatar"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:background="@drawable/bg_avatar_glow"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:textColor="#FFFFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <!-- Username -->
                <TextView
                    android:id="@+id/user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:shadowColor="@color/neon_cyan"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="8"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="用户名" />

                <!-- Admin badge -->
                <TextView
                    android:id="@+id/user_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="#337C4DFF"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/neon_purple"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:text="管理员"
                    tools:visibility="visible" />

                <!-- Register date -->
                <TextView
                    android:id="@+id/user_registered_at"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    tools:text="注册时间: 2026-05-04" />

                <!-- Stats cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/card_watched"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/stat_card_height"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/user_stat_watched_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/neon_cyan"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            tools:text="0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/user_stats_watched_label"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_watch_time"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/stat_card_height"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/user_stat_watch_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/neon_cyan"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            tools:text="0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/user_stats_watch_time_label"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/neon_cyan_dim" />

                <!-- Recent title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:text="@string/user_recent_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <!-- Recent list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_recent_watch" />

                <!-- Recent empty -->
                <TextView
                    android:id="@+id/user_recent_empty"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="@string/user_recent_empty"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- Login button -->
                <Button
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_neon_gradient"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:text="@string/user_button_login"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Logout button -->
                <Button
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="#33FF1744"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:text="@string/user_logout"
                    android:textColor="@color/neon_red"
                    android:textSize="14sp"
                    android:visibility="visible" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_user_menu"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/feed_hamburger_desc"
        android:padding="10dp"
        android:src="@drawable/ic_feed_menu_24"
        android:tint="@color/text_primary" />
</FrameLayout>
