<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="0dp">

    <FrameLayout
        android:id="@+id/thumbnail_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true">

        <ImageView
            android:id="@+id/image_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:ignore="ContentDescription" />

        <!-- Watch progress bar (amber glow line) -->
        <View
            android:id="@+id/progress_watched"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom"
            android:background="@color/neon_amber"
            android:shadowColor="@color/neon_amber"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="4"
            android:visibility="gone" />

        <!-- Duration badge -->
        <TextView
            android:id="@+id/badge_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="6dp"
            android:background="#CC0A0A0F"
            android:fontFamily="monospace"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/neon_cyan"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="03:42"
            tools:visibility="visible" />

        <!-- Selection overlay -->
        <View
            android:id="@+id/selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            tools:text="> video_title.mp4" />

        <TextView
            android:id="@+id/text_metadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            tools:text="> CAT: general  |  03:42" />
    </LinearLayout>
</FrameLayout>
