<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_tech">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Connection status bar -->
        <LinearLayout
            android:id="@+id/search_connection_status"
            android:layout_width="match_parent"
            android:layout_height="@dimen/status_bar_height"
            android:background="@drawable/bg_status_bar"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <View
                android:id="@+id/search_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_status_pulse" />

            <TextView
                android:id="@+id/search_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Search input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_search"
            style="@style/Widget.MyApplication.TextInput.Dark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            android:hint="@string/search_hint"
            app:boxBackgroundColor="#1A152040"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusTopStart="10dp"
            app:startIconDrawable="@drawable/ic_feed_search_24"
            app:startIconTint="@color/neon_cyan"
            app:endIconMode="clear_text"
            app:endIconTint="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Result count -->
        <TextView
            android:id="@+id/text_result_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:textColor="@color/neon_cyan"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="FOUND 23 RESULTS"
            tools:visibility="visible" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="6dp" />

            <LinearLayout
                android:id="@+id/empty_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="visible">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_feed_search_24"
                    android:tint="@color/text_muted" />

                <TextView
                    android:id="@+id/empty_search_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/search_empty_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/search_load_more"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="@color/neon_cyan"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_search_menu"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/feed_hamburger_desc"
        android:padding="10dp"
        android:src="@drawable/ic_feed_menu_24"
        android:tint="@color/text_primary" />
</FrameLayout>
