<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_buffering="when_playing"
        app:surface_type="texture_view"
        app:use_controller="false" />

    <!-- Neon speed indicator -->
    <TextView
        android:id="@+id/speed_indicator"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_card_glass_input"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:shadowColor="@color/neon_cyan"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="8"
        android:text="2x"
        android:textColor="@color/neon_cyan"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Glass playback controls -->
    <LinearLayout
        android:id="@+id/playback_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_glass"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="28dp"
        android:visibility="gone">

        <!-- Time display (monospace, glowing) -->
        <TextView
            android:id="@+id/text_playback_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:shadowColor="@color/neon_cyan"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="6"
            android:text="00:00 / --:--"
            android:textColor="@color/neon_cyan"
            android:textSize="14sp" />

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/playback_seek"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="2dp"
            android:max="1000"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <!-- Error overlay -->
    <FrameLayout
        android:id="@+id/error_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A0A0F"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="48dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_skip"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:fontFamily="monospace"
                android:text="@string/player_skip_next"
                android:textColor="@color/neon_cyan" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
