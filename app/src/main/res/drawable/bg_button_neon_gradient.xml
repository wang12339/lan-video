<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_cyan_dim" />
            <corners android:radius="25dp" />
        </shape>
    </item>
    <!-- Gradient主体 -->
    <item
        android:bottom="0.5dp"
        android:left="0.5dp"
        android:right="0.5dp"
        android:top="0.5dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/neon_cyan"
                android:endColor="@color/neon_purple"
                android:angle="0" />
            <corners android:radius="25dp" />
        </shape>
    </item>
</layer-list>
