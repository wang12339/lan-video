<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/neon_cyan_dim" />
        </shape>
    </item>
    <!-- Inner avatar background -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="@color/neon_cyan"
                android:endColor="@color/neon_purple"
                android:angle="135" />
            <stroke
                android:width="1dp"
                android:color="@color/neon_cyan" />
        </shape>
    </item>
</layer-list>
