<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_cyan_dim" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Glass主体 -->
    <item
        android:bottom="0.5dp"
        android:left="0.5dp"
        android:right="0.5dp"
        android:top="0.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A152040" />
            <stroke
                android:width="0.5dp"
                android:color="@color/glass_stroke_cyan" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
