<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- LAN app: cleartext HTTP is required for local network servers with dynamic IPs -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
